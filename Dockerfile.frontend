ARG NODE_IMAGE=node:24.18.0-bookworm-slim@sha256:6f7b03f7c2c8e2e784dcf9295400527b9b1270fd37b7e9a7285cf83b6951452d
ARG NGINX_IMAGE=nginx:1.28.0-alpine@sha256:30f1c0d78e0ad60901648be663a710bdadf19e4c10ac6782c235200619158284
ARG BUILD_GIT_SHA=unverified

FROM ${NODE_IMAGE} AS build
WORKDIR /app
COPY package.json package-lock.json ./
# The root prepare hook installs local Git hooks through backend/, which is intentionally absent from this image context.
RUN npm ci --ignore-scripts
COPY . .
ARG VITE_APP_DATA_MODE
ARG VITE_API_BASE_URL
ARG VITE_API_TIMEOUT_MS=15000
RUN test "$VITE_APP_DATA_MODE" = "api" && test -n "$VITE_API_BASE_URL"
ENV VITE_APP_DATA_MODE=${VITE_APP_DATA_MODE}
ENV VITE_API_BASE_URL=${VITE_API_BASE_URL}
ENV VITE_API_TIMEOUT_MS=${VITE_API_TIMEOUT_MS}
RUN npm run build && node deploy/staging/scripts/verify-frontend-build.mjs

FROM ${NGINX_IMAGE} AS runtime
ARG BUILD_GIT_SHA
LABEL org.opencontainers.image.revision=${BUILD_GIT_SHA}
COPY deploy/staging/frontend-nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
USER 101:101
EXPOSE 8080
