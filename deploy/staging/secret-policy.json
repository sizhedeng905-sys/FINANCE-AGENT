{
  "schemaVersion": "staging-secret-policy/1.0",
  "policyStatus": "engineering_default_pending_h14",
  "freshness": {
    "maxAgeDays": 90,
    "warningDays": 14,
    "futureSkewSeconds": 300,
    "minBytes": 8,
    "maxBytes": 65536
  },
  "secrets": [
    { "name": "postgres_superuser_password", "category": "database_credential", "rotationSet": "postgres-superuser", "consumers": ["postgres"] },
    { "name": "migration_password", "category": "database_credential", "rotationSet": "postgres-migration", "consumers": ["postgres"] },
    { "name": "migration_database_url", "category": "derived_connection", "rotationSet": "postgres-migration", "consumers": ["backup", "migrate"] },
    { "name": "runtime_password", "category": "database_credential", "rotationSet": "postgres-runtime", "consumers": ["postgres"] },
    { "name": "runtime_database_url", "category": "derived_connection", "rotationSet": "postgres-runtime", "consumers": ["backend-api", "worker"] },
    { "name": "backup_password", "category": "database_credential", "rotationSet": "postgres-backup", "consumers": ["postgres"] },
    { "name": "backup_database_url", "category": "derived_connection", "rotationSet": "postgres-backup", "consumers": ["backup"] },
    { "name": "restore_password", "category": "database_credential", "rotationSet": "postgres-restore", "consumers": ["postgres"] },
    { "name": "restore_database_url", "category": "derived_connection", "rotationSet": "postgres-restore", "consumers": ["backup"] },
    { "name": "jwt_secret", "category": "application_signing", "rotationSet": "jwt-signing", "consumers": ["backend-api", "worker"] },
    { "name": "redis_password", "category": "cache_credential", "rotationSet": "redis-runtime", "consumers": ["redis"] },
    { "name": "redis_url", "category": "derived_connection", "rotationSet": "redis-runtime", "consumers": ["backend-api", "worker"] },
    { "name": "minio_root_user", "category": "object_admin_credential", "rotationSet": "minio-root", "consumers": ["backup", "minio", "minio-init"] },
    { "name": "minio_root_password", "category": "object_admin_credential", "rotationSet": "minio-root", "consumers": ["backup", "minio", "minio-init"] },
    { "name": "s3_access_key_id", "category": "object_runtime_credential", "rotationSet": "s3-runtime", "consumers": ["backend-api", "minio-init", "worker"] },
    { "name": "s3_secret_access_key", "category": "object_runtime_credential", "rotationSet": "s3-runtime", "consumers": ["backend-api", "minio-init", "worker"] },
    { "name": "metrics_token", "category": "monitoring_credential", "rotationSet": "metrics-access", "consumers": ["backend-api", "prometheus", "worker"] },
    { "name": "grafana_admin_password", "category": "monitoring_credential", "rotationSet": "grafana-admin", "consumers": ["grafana"] },
    { "name": "staging_seed_password", "category": "synthetic_demo_credential", "rotationSet": "staging-seed", "consumers": ["migrate"], "maxAgeDays": 30, "warningDays": 7 },
    { "name": "alert_webhook_url", "category": "alert_endpoint_credential", "rotationSet": "alert-webhook", "consumers": ["alertmanager"] }
  ],
  "rotationSets": [
    { "id": "postgres-superuser", "members": ["postgres_superuser_password"], "mode": "coordinated_provider_and_consumers", "consumerOrder": ["postgres"], "impactCode": "DATABASE_ADMIN_MAINTENANCE" },
    { "id": "postgres-migration", "members": ["migration_password", "migration_database_url"], "mode": "coordinated_provider_and_consumers", "consumerOrder": ["postgres", "migrate", "backup"], "impactCode": "DATABASE_ROLE_AND_DERIVED_URL" },
    { "id": "postgres-runtime", "members": ["runtime_password", "runtime_database_url"], "mode": "coordinated_provider_and_consumers", "consumerOrder": ["postgres", "backend-api", "worker"], "impactCode": "DATABASE_ROLE_AND_DERIVED_URL" },
    { "id": "postgres-backup", "members": ["backup_password", "backup_database_url"], "mode": "coordinated_provider_and_consumers", "consumerOrder": ["postgres", "backup"], "impactCode": "DATABASE_ROLE_AND_DERIVED_URL" },
    { "id": "postgres-restore", "members": ["restore_password", "restore_database_url"], "mode": "coordinated_provider_and_consumers", "consumerOrder": ["postgres", "backup"], "impactCode": "DATABASE_ROLE_AND_DERIVED_URL" },
    { "id": "jwt-signing", "members": ["jwt_secret"], "mode": "session_invalidating_restart", "consumerOrder": ["backend-api", "worker"], "impactCode": "ACTIVE_SESSIONS_INVALIDATED" },
    { "id": "redis-runtime", "members": ["redis_password", "redis_url"], "mode": "coordinated_provider_and_consumers", "consumerOrder": ["redis", "backend-api", "worker"], "impactCode": "CACHE_CREDENTIAL_AND_DERIVED_URL" },
    { "id": "minio-root", "members": ["minio_root_user", "minio_root_password"], "mode": "coordinated_provider_and_consumers", "consumerOrder": ["minio", "minio-init", "backup"], "impactCode": "OBJECT_ADMIN_MAINTENANCE" },
    { "id": "s3-runtime", "members": ["s3_access_key_id", "s3_secret_access_key"], "mode": "coordinated_provider_and_consumers", "consumerOrder": ["minio-init", "backend-api", "worker"], "impactCode": "OBJECT_RUNTIME_DUAL_CREDENTIAL" },
    { "id": "metrics-access", "members": ["metrics_token"], "mode": "coordinated_provider_and_consumers", "consumerOrder": ["backend-api", "worker", "prometheus"], "impactCode": "METRICS_SCRAPE_RELOAD" },
    { "id": "grafana-admin", "members": ["grafana_admin_password"], "mode": "restart_consumers", "consumerOrder": ["grafana"], "impactCode": "GRAFANA_ADMIN_RESTART" },
    { "id": "staging-seed", "members": ["staging_seed_password"], "mode": "local_synthetic_only", "consumerOrder": ["migrate"], "impactCode": "TARGET_SEED_MUST_REMAIN_DISABLED" },
    { "id": "alert-webhook", "members": ["alert_webhook_url"], "mode": "restart_consumers", "consumerOrder": ["alertmanager"], "impactCode": "ALERT_ROUTE_RELOAD_AND_SYNTHETIC_CHECK" }
  ]
}
