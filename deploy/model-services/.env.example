# Run `npm run model:init` from the repository root to create an ignored local .env.
# Windows example: C:/Users/you/path/to/FINANCE-AGENT/model
MODEL_ROOT=/absolute/path/to/model
LOCAL_MODEL_API_KEY=replace-with-at-least-32-random-characters
MODEL_START_TIMEOUT_MS=900000

VLLM_IMAGE=vllm/vllm-openai:v0.23.0

QWEN_TEXT_MODEL=/models/Qwen3-14B-AWQ
QWEN_TEXT_MAX_MODEL_LEN=8192
QWEN_TEXT_GPU_MEMORY_UTILIZATION=0.52

QWEN_VL_MODEL=/models/Qwen3-VL-8B-Instruct
QWEN_VL_MAX_MODEL_LEN=8192

QWEN_EMBEDDING_MODEL=/models/Qwen3-Embedding-8B
QWEN_EMBEDDING_MAX_MODEL_LEN=8192
ON_DEMAND_GPU_MEMORY_UTILIZATION=0.88

PADDLE_OCR_BASE_IMAGE=ccr-2vdh3abv-pub.cnc.bj.baidubce.com/paddlepaddle/paddleocr-vl:latest-nvidia-gpu-sm120
PADDLE_OCR_MODEL=/models/PaddleOCR-VL
PADDLE_OCR_PIPELINE_VERSION=v1
PADDLE_OCR_DEVICE=gpu:0
OCR_MAX_UPLOAD_SIZE_MB=50
OCR_MAX_TEMPLATE_FIELDS=200
