{
  "name": "financial-agent",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=24.18.0 <25"
  },
  "scripts": {
    "prepare": "node backend/scripts/install-git-hooks.mjs",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test:runtime": "node --test frontend-tests/runtime-config.test.mjs",
    "test:e2e:prepare": "node backend/scripts/prepare-e2e.mjs",
    "test:e2e": "npm run test:e2e:prepare && playwright test",
    "test:e2e:ocr-real": "npm run test:e2e:prepare && playwright test --config playwright.ocr-real.config.ts",
    "test:e2e:headed": "npm run test:e2e:prepare && playwright test --headed",
    "demo:config:test": "node --test backend/scripts/demo-environment.test.mjs",
    "demo:reset": "node backend/scripts/demo-environment.mjs reset",
    "demo:verify": "node backend/scripts/demo-environment.mjs verify",
    "demo:api": "node backend/scripts/demo-environment.mjs api",
    "demo:web": "node backend/scripts/demo-environment.mjs web",
    "demo:test": "npm run demo:reset && playwright test e2e/friday-demo.spec.ts",
    "check:docs": "node backend/scripts/check-markdown-links.mjs",
    "check:hygiene": "node backend/scripts/check-repository-hygiene.mjs",
    "check:hygiene:staged": "node backend/scripts/check-repository-hygiene.mjs --staged",
    "realdata:scan": "npm --prefix backend run realdata:scan --",
    "realdata:xlsx-profile": "npm --prefix backend run realdata:xlsx-profile --",
    "realdata:large-xlsx-profile": "npm --prefix backend run realdata:large-xlsx-profile --",
    "realdata:ocr-prepare": "npm --prefix backend run realdata:ocr-prepare --",
    "realdata:ocr-evaluate": "npm --prefix backend run realdata:ocr-evaluate --",
    "realdata:ocr-page-ranges": "npm --prefix backend run realdata:ocr-page-ranges --",
    "realdata:ai-benchmark": "npm --prefix backend run realdata:ai-benchmark --",
    "realdata:resilience": "npm --prefix backend run realdata:resilience --",
    "realdata:model-resilience": "npm --prefix backend run realdata:model-resilience --",
    "model:soak": "npm --prefix backend run model:soak --",
    "model:init": "node backend/scripts/model-services.mjs init",
    "model:check": "node backend/scripts/model-services.mjs check resident",
    "model:check:all": "node backend/scripts/model-services.mjs check all",
    "model:resident": "node backend/scripts/model-services.mjs start-resident",
    "model:on-demand": "node backend/scripts/model-services.mjs start-on-demand",
    "model:restore": "node backend/scripts/model-services.mjs stop-on-demand",
    "model:status": "node backend/scripts/model-services.mjs status",
    "model:stop": "node backend/scripts/model-services.mjs stop-all",
    "staging:init": "node deploy/staging/scripts/init-staging.mjs",
    "staging:config:test": "node --test deploy/staging/scripts/managed-environment.test.mjs deploy/staging/scripts/deployment-environment.test.mjs deploy/staging/scripts/target-profile.test.mjs",
    "staging:target:check": "node deploy/staging/scripts/target-profile-check.mjs",
    "staging:sbom:test": "node --test deploy/staging/scripts/generate-sbom.test.mjs",
    "staging:check": "node deploy/staging/scripts/verify-config.mjs",
    "staging:backup-integrity:test": "node deploy/staging/scripts/test-backup-integrity.mjs",
    "staging:image-integrity:test": "node deploy/staging/scripts/test-image-integrity.mjs",
    "staging:logs:test": "node --test deploy/staging/scripts/runtime-log-policy.test.mjs",
    "staging:logs:check": "node deploy/staging/scripts/verify-runtime-logs.mjs",
    "staging:current-release": "node deploy/staging/scripts/current-release-manifest.mjs",
    "staging:lock-images": "node deploy/staging/scripts/lock-images.mjs",
    "staging:smoke": "node deploy/staging/scripts/smoke-test.mjs && node deploy/staging/scripts/browser-smoke.mjs",
    "staging:frontend:check": "node deploy/staging/scripts/verify-frontend-build.mjs",
    "staging:release": "node deploy/staging/scripts/release.mjs",
    "staging:rollback": "node deploy/staging/scripts/rollback.mjs"
  },
  "dependencies": {
    "@ant-design/icons": "^5.5.1",
    "antd": "^5.22.5",
    "dayjs": "^1.11.13",
    "pdfjs-dist": "6.1.200",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.7.0",
    "typescript": "~5.6.3",
    "vite": "^6.4.3"
  }
}
