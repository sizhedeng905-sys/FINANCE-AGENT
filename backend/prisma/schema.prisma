generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  employee
  finance
  reviewer
  boss
}

enum UserStatus {
  active
  disabled
}

enum ProjectStatus {
  active
  archived
}

enum DataRecordType {
  cost
  revenue
  reimbursement
  transport
  labor
  other
}

enum FieldType {
  text
  number
  money
  date
  select
  file
  textarea
}

enum SemanticType {
  amount
  date
  person
  vehicle
  project
  location
  category
  remark
  file
}

enum RecordSourceType {
  manual
  excel
  ocr
  work_order
}

enum BusinessRecordStatus {
  draft
  pending_confirm
  confirmed
  rejected
}

model User {
  id           String     @id @default(cuid())
  username     String     @unique
  passwordHash String     @map("password_hash")
  name         String
  role         UserRole
  department   String?
  phone        String?
  status       UserStatus @default(active)
  createdBy    String?    @map("created_by")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  auditLogs AuditLog[]

  @@map("users")
}

model AuditLog {
  id            String   @id @default(cuid())
  actorUserId   String?  @map("actor_user_id")
  actorUsername String?  @map("actor_username")
  action        String
  resourceType  String   @map("resource_type")
  resourceId    String?  @map("resource_id")
  metadata      Json?
  ip            String?
  userAgent     String?  @map("user_agent")
  createdAt     DateTime @default(now()) @map("created_at")

  actor User? @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([resourceType, resourceId])
  @@map("audit_logs")
}

model Project {
  id           String        @id @default(cuid())
  name         String
  customerName String        @map("customer_name")
  description  String?
  ownerName    String        @map("owner_name")
  status       ProjectStatus @default(active)
  createdBy    String?       @map("created_by")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  projectTemplates ProjectTemplate[]
  businessRecords  BusinessRecord[]

  @@index([status])
  @@map("projects")
}

model Template {
  id          String         @id @default(cuid())
  name        String
  recordType  DataRecordType @map("record_type")
  description String?
  isSystem    Boolean        @default(false) @map("is_system")
  createdBy   String?        @map("created_by")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  templateFields   TemplateField[]
  projectTemplates ProjectTemplate[]
  businessRecords  BusinessRecord[]

  @@index([recordType])
  @@map("templates")
}

model FieldDefinition {
  id           String       @id @default(cuid())
  fieldKey     String       @unique @map("field_key")
  fieldName    String       @map("field_name")
  fieldType    FieldType    @map("field_type")
  unit         String?
  semanticType SemanticType @map("semantic_type")
  aliases      Json?
  description  String?
  isActive     Boolean      @default(true) @map("is_active")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  templateFields TemplateField[]
  recordValues   RecordValue[]

  @@index([isActive])
  @@map("field_definitions")
}

model TemplateField {
  id           String   @id @default(cuid())
  templateId   String   @map("template_id")
  fieldId      String   @map("field_id")
  isRequired   Boolean  @default(false) @map("is_required")
  isVisible    Boolean  @default(true) @map("is_visible")
  displayOrder Int      @default(0) @map("display_order")
  defaultValue String?  @map("default_value")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  template Template        @relation(fields: [templateId], references: [id], onDelete: Cascade)
  field    FieldDefinition @relation(fields: [fieldId], references: [id], onDelete: Restrict)

  @@unique([templateId, fieldId])
  @@index([fieldId])
  @@map("template_fields")
}

model ProjectTemplate {
  id         String   @id @default(cuid())
  projectId  String   @map("project_id")
  templateId String   @map("template_id")
  customName String?  @map("custom_name")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([projectId, templateId])
  @@index([templateId])
  @@map("project_templates")
}

model BusinessRecord {
  id          String               @id @default(cuid())
  projectId   String               @map("project_id")
  templateId  String               @map("template_id")
  recordType  DataRecordType       @map("record_type")
  recordDate  DateTime             @map("record_date")
  amount      Decimal              @default(0) @db.Decimal(18, 2)
  category    String?
  subCategory String?              @map("sub_category")
  description String?
  sourceType  RecordSourceType     @default(manual) @map("source_type")
  sourceId    String               @default("manual") @map("source_id")
  status      BusinessRecordStatus @default(pending_confirm)
  attachments Json?
  createdBy   String?              @map("created_by")
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")
  confirmedAt DateTime?            @map("confirmed_at")
  confirmedBy String?              @map("confirmed_by")
  voidedAt    DateTime?            @map("voided_at")
  voidedBy    String?              @map("voided_by")

  project  Project       @relation(fields: [projectId], references: [id], onDelete: Restrict)
  template Template      @relation(fields: [templateId], references: [id], onDelete: Restrict)
  values   RecordValue[]

  @@index([projectId])
  @@index([templateId])
  @@index([status])
  @@index([recordDate])
  @@map("business_records")
}

model RecordValue {
  id          String    @id @default(cuid())
  recordId    String    @map("record_id")
  fieldId     String    @map("field_id")
  fieldName   String    @map("field_name")
  valueText   String?   @map("value_text")
  valueNumber Decimal?  @map("value_number") @db.Decimal(18, 4)
  valueDate   DateTime? @map("value_date")
  valueJson   Json?     @map("value_json")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  record BusinessRecord  @relation(fields: [recordId], references: [id], onDelete: Cascade)
  field  FieldDefinition @relation(fields: [fieldId], references: [id], onDelete: Restrict)

  @@unique([recordId, fieldId])
  @@index([fieldId])
  @@map("record_values")
}

model LedgerEvent {
  id            String   @id @default(cuid())
  eventType     String   @map("event_type")
  aggregateType String   @map("aggregate_type")
  aggregateId   String   @map("aggregate_id")
  actorUserId   String?  @map("actor_user_id")
  actorUsername String?  @map("actor_username")
  payload       Json?
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([aggregateType, aggregateId])
  @@index([eventType])
  @@map("ledger_events")
}
