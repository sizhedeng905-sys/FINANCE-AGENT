  latencyMs          Int      @default(0) @map("latency_ms")
  success            Boolean  @default(true)
  errorMessage       String?  @map("error_message")
  endpointSnapshot   String?  @map("endpoint_snapshot")
  inputHash          String?  @map("input_hash")
  correlationId      String?  @map("correlation_id")
  attemptNo          Int      @default(1) @map("attempt_no")
  fallback           Boolean  @default(false)
  createdBy          String?  @map("created_by")
  createdAt          DateTime @default(now()) @map("created_at")

  conversation  AiConversation?  @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  deployment    ModelDeployment? @relation(fields: [deploymentId], references: [id], onDelete: SetNull)
  modelConfig   AiModelConfig?   @relation(fields: [modelConfigId], references: [id], onDelete: SetNull)
  promptVersion AiPromptVersion? @relation(fields: [promptVersionId], references: [id], onDelete: SetNull)

  @@index([conversationId])
  @@index([deploymentId, createdAt])
  @@index([modelName, createdAt])
  @@index([createdAt])
  @@index([correlationId])
  @@map("ai_call_logs")
}

model RecordValue {
  id          String    @id @default(cuid())
  recordId    String    @map("record_id")
  fieldId     String    @map("field_id")
  fieldName   String    @map("field_name")
  valueText   String?   @map("value_text")
  valueNumber Decimal?  @map("value_number") @db.Decimal(18, 4)
  valueDate   DateTime? @map("value_date")
  valueJson   Json?     @map("value_json")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  record BusinessRecord  @relation(fields: [recordId], references: [id], onDelete: Cascade)
  field  FieldDefinition @relation(fields: [fieldId], references: [id], onDelete: Restrict)

  @@unique([recordId, fieldId])
  @@index([fieldId])
  @@map("record_values")
}

model LedgerEvent {
  id             String   @id @default(cuid())
  eventType      String   @map("event_type")
  aggregateType  String   @map("aggregate_type")
  aggregateId    String   @map("aggregate_id")
  actorUserId    String?  @map("actor_user_id")
  actorUsername  String?  @map("actor_username")
  idempotencyKey String?  @unique @map("idempotency_key")
  payload        Json?
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([aggregateType, aggregateId])
  @@index([eventType])
  @@map("ledger_events")
}

model IdempotencyKey {
  id             String    @id @default(cuid())
  key            String    @db.VarChar(128)
  requestMethod  String    @map("request_method") @db.VarChar(16)
  requestPath    String    @map("request_path")
  requestHash    String    @map("request_hash") @db.VarChar(64)
  responseStatus Int?      @map("response_status")
  responseBody   Json?     @map("response_body")
  status         String    @default("processing") @db.VarChar(32)
  lockedUntil    DateTime? @map("locked_until")
  createdBy      String    @map("created_by")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  expiresAt      DateTime? @map("expires_at")

  @@unique([createdBy, requestMethod, requestPath, key], map: "uq_idempotency_actor_operation_key")
  @@index([status], map: "idx_idempotency_status")
  @@index([expiresAt], map: "idx_idempotency_expires")
  @@map("idempotency_keys")
}

model RetentionRun {
  id                  String             @id @default(cuid())
  dataClass           RetentionDataClass @map("data_class")
  status              RetentionRunStatus @default(queued)
  dryRun              Boolean            @default(true) @map("dry_run")
  cutoffAt            DateTime           @map("cutoff_at")
  batchSize           Int                @map("batch_size")
  policyVersion       String             @default("retention-framework/1.0-pending-h14") @map("policy_version")
  requestedBy         String?            @map("requested_by")
  requestedByUsername String?            @map("requested_by_username")
  attemptCount        Int                @default(0) @map("attempt_count")
  maxAttempts         Int                @default(3) @map("max_attempts")
  leaseToken          String?            @map("lease_token")
  leaseUntil          DateTime?          @map("lease_until")
  beforeCount         Int                @default(0) @map("before_count")
  afterCount          Int                @default(0) @map("after_count")
  scannedCount        Int                @default(0) @map("scanned_count")
  eligibleCount       Int                @default(0) @map("eligible_count")
  heldCount           Int                @default(0) @map("held_count")
  protectedCount      Int                @default(0) @map("protected_count")
  deletedCount        Int                @default(0) @map("deleted_count")
  evidence            Json               @default("{}")
  errorCode           String?            @map("error_code")
  errorMessage        String?            @map("error_message")
  startedAt           DateTime?          @map("started_at")
  completedAt         DateTime?          @map("completed_at")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")

  requester User? @relation("RetentionRunRequester", fields: [requestedBy], references: [id], onDelete: SetNull)

  @@index([status, leaseUntil])
  @@index([dataClass, createdAt])
  @@map("retention_runs")
}

model RetentionLegalHold {
  id                String   @id @default(cuid())
  resourceType      String   @map("resource_type")
  resourceId        String   @map("resource_id")
  reason            String
  active            Boolean  @default(true)
  createdBy         String?  @map("created_by")
  createdByUsername String?  @map("created_by_username")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  creator User? @relation("RetentionLegalHoldCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@unique([resourceType, resourceId])
  @@index([active, resourceType])
  @@map("retention_legal_holds")
}

model StepUpGrant {
  id            String            @id @default(cuid())
  tokenIdHash   String            @unique @map("token_id_hash") @db.VarChar(64)
  userId        String            @map("user_id")
  sessionIdHash String            @map("session_id_hash") @db.VarChar(64)
  action        String            @db.VarChar(100)
  resourceType  String            @map("resource_type") @db.VarChar(100)
  resourceId    String            @map("resource_id") @db.VarChar(256)
  roleSnapshot  UserRole          @map("role_snapshot")
  tokenVersion  Int               @map("token_version")
  status        StepUpGrantStatus @default(active)
  maxUses       Int               @default(1) @map("max_uses")
  useCount      Int               @default(0) @map("use_count")
  expiresAt     DateTime          @map("expires_at")
  consumedAt    DateTime?         @map("consumed_at")
  revokedAt     DateTime?         @map("revoked_at")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, expiresAt])
  @@index([action, resourceType, resourceId])
  @@map("step_up_grants")
}
