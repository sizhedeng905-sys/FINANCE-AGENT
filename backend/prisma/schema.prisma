model ModelDeployment {
  id                  String                @id @default(cuid())
  deploymentKey       String                @unique @map("deployment_key")
  provider            String
  modelName           String                @map("model_name")
  modelVersion        String?               @map("model_version")
  endpoint            String?
  secretRef           String?               @map("secret_ref")
  taskTypes           Json                  @default("[]") @map("task_types")
  maxConcurrency      Int                   @default(1) @map("max_concurrency")
  timeoutMs           Int                   @default(30000) @map("timeout_ms")
  isLocal             Boolean               @default(true) @map("is_local")
  isEnabled           Boolean               @default(false) @map("is_enabled")
  status              ModelDeploymentStatus @default(unknown)
  lastHealthAt        DateTime?             @map("last_health_at")
  lastHealthLatencyMs Int?                  @map("last_health_latency_ms")
  lastError           String?               @map("last_error")
  createdAt           DateTime              @default(now()) @map("created_at")
  updatedAt           DateTime              @updatedAt @map("updated_at")

  routes       TaskModelRoute[]
  callAttempts AiCallAttempt[]

  @@index([provider, isEnabled])
  @@index([status])
  @@map("model_deployments")
}

model TaskModelRoute {
