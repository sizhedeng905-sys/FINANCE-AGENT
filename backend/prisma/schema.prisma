generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  employee
  finance
  reviewer
  boss
}

enum UserStatus {
  active
  disabled
}

enum ProjectStatus {
  active
  archived
}

enum DataRecordType {
  cost
  revenue
  reimbursement
  transport
  labor
  other
}

enum FieldType {
  text
  number
  money
  date
  select
  file
  textarea
}

enum SemanticType {
  amount
  date
  person
  vehicle
  project
  location
  category
  remark
  file
}

enum RecordSourceType {
  manual
  excel
  ocr
  work_order
}

enum BusinessRecordStatus {
  draft
  pending_confirm
  confirmed
  rejected
}

enum WorkOrderType {
  transport
  expense
  other
}

enum WorkOrderStatus {
  draft
  finance_reviewing
  finance_rejected
  reviewer_reviewing
  reviewer_rejected
  ai_reviewing
  ai_passed
  ai_flagged
  boss_pending
  boss_rejected
  completed
  returned_for_supplement
}

enum RiskLevel {
  low
  medium
  high
}

enum NotificationType {
  urgent
  audit
  system
  boss_approval
}

model User {
  id           String     @id @default(cuid())
  username     String     @unique
  passwordHash String     @map("password_hash")
  name         String
  role         UserRole
  department   String?
  phone        String?
  status       UserStatus @default(active)
  createdBy    String?    @map("created_by")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  auditLogs         AuditLog[]
  createdWorkOrders WorkOrder[]         @relation("WorkOrderCreator")
  approvals         Approval[]
  timelineEntries   WorkOrderTimeline[]

  @@map("users")
}

model AuditLog {
  id            String   @id @default(cuid())
  actorUserId   String?  @map("actor_user_id")
  actorUsername String?  @map("actor_username")
  action        String
  resourceType  String   @map("resource_type")
  resourceId    String?  @map("resource_id")
  metadata      Json?
  ip            String?
  userAgent     String?  @map("user_agent")
  createdAt     DateTime @default(now()) @map("created_at")

  actor User? @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([resourceType, resourceId])
  @@map("audit_logs")
}

model Project {
  id           String        @id @default(cuid())
  name         String
  customerName String        @map("customer_name")
  description  String?
  ownerName    String        @map("owner_name")
  status       ProjectStatus @default(active)
  createdBy    String?       @map("created_by")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  projectTemplates ProjectTemplate[]
  businessRecords  BusinessRecord[]
  workOrders       WorkOrder[]

  @@index([status])
  @@map("projects")
}

model Template {
  id          String         @id @default(cuid())
  name        String
  recordType  DataRecordType @map("record_type")
  description String?
  isSystem    Boolean        @default(false) @map("is_system")
  createdBy   String?        @map("created_by")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  templateFields   TemplateField[]
  projectTemplates ProjectTemplate[]
  businessRecords  BusinessRecord[]

  @@index([recordType])
  @@map("templates")
}

model FieldDefinition {
  id           String       @id @default(cuid())
  fieldKey     String       @unique @map("field_key")
  fieldName    String       @map("field_name")
  fieldType    FieldType    @map("field_type")
  unit         String?
  semanticType SemanticType @map("semantic_type")
  aliases      Json?
  description  String?
  isActive     Boolean      @default(true) @map("is_active")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  templateFields TemplateField[]
  recordValues   RecordValue[]

  @@index([isActive])
  @@map("field_definitions")
}

model TemplateField {
  id           String   @id @default(cuid())
  templateId   String   @map("template_id")
  fieldId      String   @map("field_id")
  isRequired   Boolean  @default(false) @map("is_required")
  isVisible    Boolean  @default(true) @map("is_visible")
  displayOrder Int      @default(0) @map("display_order")
  defaultValue String?  @map("default_value")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  template Template        @relation(fields: [templateId], references: [id], onDelete: Cascade)
  field    FieldDefinition @relation(fields: [fieldId], references: [id], onDelete: Restrict)

  @@unique([templateId, fieldId])
  @@index([fieldId])
  @@map("template_fields")
}

model ProjectTemplate {
  id         String   @id @default(cuid())
  projectId  String   @map("project_id")
  templateId String   @map("template_id")
  customName String?  @map("custom_name")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([projectId, templateId])
  @@index([templateId])
  @@map("project_templates")
}

model BusinessRecord {
  id          String               @id @default(cuid())
  projectId   String               @map("project_id")
  templateId  String               @map("template_id")
  recordType  DataRecordType       @map("record_type")
  recordDate  DateTime             @map("record_date")
  amount      Decimal              @default(0) @db.Decimal(18, 2)
  category    String?
  subCategory String?              @map("sub_category")
  description String?
  sourceType  RecordSourceType     @default(manual) @map("source_type")
  sourceId    String               @default("manual") @map("source_id")
  status      BusinessRecordStatus @default(pending_confirm)
  attachments Json?
  createdBy   String?              @map("created_by")
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")
  confirmedAt DateTime?            @map("confirmed_at")
  confirmedBy String?              @map("confirmed_by")
  voidedAt    DateTime?            @map("voided_at")
  voidedBy    String?              @map("voided_by")

  project  Project       @relation(fields: [projectId], references: [id], onDelete: Restrict)
  template Template      @relation(fields: [templateId], references: [id], onDelete: Restrict)
  values   RecordValue[]
  generatedFromWorkOrder WorkOrder? @relation("GeneratedRecord")

  @@index([projectId])
  @@index([templateId])
  @@index([status])
  @@index([recordDate])
  @@map("business_records")
}

model WorkOrder {
  id                String          @id @default(cuid())
  orderNo           String          @unique @map("order_no")
  type              WorkOrderType
  projectId         String          @map("project_id")
  projectName       String          @map("project_name")
  customerName      String?         @map("customer_name")
  creatorId         String          @map("creator_id")
  creatorName       String          @map("creator_name")
  amount            Decimal         @default(0) @db.Decimal(14, 2)
  income            Decimal         @default(0) @db.Decimal(14, 2)
  cost              Decimal         @default(0) @db.Decimal(14, 2)
  profit            Decimal         @default(0) @db.Decimal(14, 2)
  status            WorkOrderStatus @default(finance_reviewing)
  riskLevel         RiskLevel       @default(low) @map("risk_level")
  description       String?
  occurredDate      DateTime        @map("occurred_date")
  extraValues       Json?           @map("extra_values")
  financeOpinion    String?         @map("finance_opinion")
  reviewerOpinion   String?         @map("reviewer_opinion")
  aiSummary         String?         @map("ai_summary")
  bossOpinion       String?         @map("boss_opinion")
  urgent            Boolean         @default(false)
  urgentReason      String?         @map("urgent_reason")
  urgentTime        DateTime?       @map("urgent_time")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  completedAt       DateTime?       @map("completed_at")
  generatedRecordId String?         @unique @map("generated_record_id")

  project         Project               @relation(fields: [projectId], references: [id], onDelete: Restrict)
  creator         User                  @relation("WorkOrderCreator", fields: [creatorId], references: [id], onDelete: Restrict)
  generatedRecord BusinessRecord?       @relation("GeneratedRecord", fields: [generatedRecordId], references: [id], onDelete: SetNull)
  attachments     WorkOrderAttachment[]
  timeline        WorkOrderTimeline[]
  approvals       Approval[]
  notifications   Notification[]

  @@index([creatorId])
  @@index([projectId])
  @@index([status])
  @@index([createdAt])
  @@map("work_orders")
}

model WorkOrderAttachment {
  id          String   @id @default(cuid())
  workOrderId String   @map("work_order_id")
  rawFileId   String   @map("raw_file_id")
  uploadedBy  String?  @map("uploaded_by")
  createdAt   DateTime @default(now()) @map("created_at")

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@unique([workOrderId, rawFileId])
  @@index([rawFileId])
  @@map("work_order_attachments")
}

model WorkOrderTimeline {
  id           String           @id @default(cuid())
  workOrderId  String           @map("work_order_id")
  operatorId   String?          @map("operator_id")
  operatorName String?          @map("operator_name")
  role         String
  action       String
  comment      String?
  fromStatus   WorkOrderStatus? @map("from_status")
  toStatus     WorkOrderStatus? @map("to_status")
  createdAt    DateTime         @default(now()) @map("created_at")

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  operator  User?     @relation(fields: [operatorId], references: [id], onDelete: SetNull)

  @@index([workOrderId, createdAt])
  @@map("work_order_timeline")
}

model Approval {
  id           String   @id @default(cuid())
  workOrderId  String   @map("work_order_id")
  approverId   String?  @map("approver_id")
  approverRole String   @map("approver_role")
  action       String
  comment      String?
  createdAt    DateTime @default(now()) @map("created_at")

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  approver  User?     @relation(fields: [approverId], references: [id], onDelete: SetNull)

  @@index([workOrderId])
  @@index([approverId])
  @@map("approvals")
}

model Notification {
  id                 String           @id @default(cuid())
  title              String
  content            String
  type               NotificationType
  senderId           String?          @map("sender_id")
  senderName         String?          @map("sender_name")
  targetRole         UserRole?        @map("target_role")
  targetUserId       String?          @map("target_user_id")
  relatedWorkOrderId String?          @map("related_work_order_id")
  read               Boolean          @default(false)
  createdAt          DateTime         @default(now()) @map("created_at")
  readAt             DateTime?        @map("read_at")

  workOrder WorkOrder? @relation(fields: [relatedWorkOrderId], references: [id], onDelete: Cascade)

  @@index([targetRole, read])
  @@index([targetUserId, read])
  @@index([relatedWorkOrderId])
  @@map("notifications")
}

model RecordValue {
  id          String    @id @default(cuid())
  recordId    String    @map("record_id")
  fieldId     String    @map("field_id")
  fieldName   String    @map("field_name")
  valueText   String?   @map("value_text")
  valueNumber Decimal?  @map("value_number") @db.Decimal(18, 4)
  valueDate   DateTime? @map("value_date")
  valueJson   Json?     @map("value_json")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  record BusinessRecord  @relation(fields: [recordId], references: [id], onDelete: Cascade)
  field  FieldDefinition @relation(fields: [fieldId], references: [id], onDelete: Restrict)

  @@unique([recordId, fieldId])
  @@index([fieldId])
  @@map("record_values")
}

model LedgerEvent {
  id            String   @id @default(cuid())
  eventType     String   @map("event_type")
  aggregateType String   @map("aggregate_type")
  aggregateId   String   @map("aggregate_id")
  actorUserId   String?  @map("actor_user_id")
  actorUsername String?  @map("actor_username")
  payload       Json?
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([aggregateType, aggregateId])
  @@index([eventType])
  @@map("ledger_events")
}
