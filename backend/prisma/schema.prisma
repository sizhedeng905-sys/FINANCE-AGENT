generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  employee
  finance
  reviewer
  boss
  admin
  auditor
}

enum UserStatus {
  active
  disabled
}

enum ProjectStatus {
  active
  archived
}

enum DataRecordType {
  cost
  revenue
  reimbursement
  transport
  labor
  other
}

enum AccountingDirection {
  income
  expense
}

enum RecordDataLayer {
  actual
  reconciliation
  budget
}

enum FieldType {
  text
  number
  money
  date
  select
  file
  textarea
}

enum SemanticType {
  amount
  date
  person
  vehicle
  project
  location
  category
  remark
  file
}

enum RecordSourceType {
  manual
  excel
  ocr
  work_order
}

enum BusinessRecordStatus {
  draft
  pending_confirm
  confirmed
  rejected
}

enum WorkOrderType {
  transport
  expense
  other
}

enum WorkOrderStatus {
  draft
  finance_reviewing
  finance_rejected
  reviewer_reviewing
  reviewer_rejected
  ai_reviewing
  ai_passed
  ai_flagged
  boss_pending
  boss_rejected
  completed
  returned_for_supplement
}

enum RiskLevel {
  low
  medium
  high
}

enum NotificationType {
  urgent
  audit
  system
  boss_approval
}

enum RawFileStatus {
  uploaded
  parsed
  failed
  voided
}

enum ImportTaskStatus {
  uploaded
  parsing
  parsed
  mapping
  pending_confirm
  confirming
  confirmed
  confirmation_failed
  failed
  cancelled
}

enum ImportRowStatus {
  pending
  mapped
  error
  confirmed
  duplicate
  ignored
}

enum MappingDecisionType {
  profile
  field_key
  exact_name
  alias
  normalized
  fuzzy
  manual
  ignored
}

enum MappingProfileStatus {
  active
  stale
  revoked
}

enum FieldSuggestionStatus {
  pending
  approved
  rejected
  mapped_to_existing
}

enum OcrTaskStatus {
  uploaded
  queued
  processing
  pending_confirm
  confirmed
  failed
  cancelled
}

enum OcrAttemptStatus {
  queued
  processing
  succeeded
  failed
}

enum FileScanStatus {
  pending
  clean
  infected
  failed
}

enum AnomalyStatus {
  open
  acknowledged
  resolved
  ignored
  accepted_risk
  false_positive
}

enum AiMessageRole {
  user
  assistant
}

enum ModelDeploymentStatus {
  unknown
  healthy
  unhealthy
  disabled
}

enum AiTaskStatus {
  queued
  running
  succeeded
  failed
  cancelled
}

enum AiCallAttemptStatus {
  queued
  running
  succeeded
  failed
}

enum RetentionDataClass {
  auth_security_grant
  ai_conversation_content
  ai_provider_payload
  ai_task_payload
  ocr_intermediate
  import_intermediate
  notification
  idempotency_response
  audit_event
  ledger_event
}

enum RetentionRunStatus {
  queued
  running
  completed
  failed
}

enum StepUpGrantStatus {
  active
  consumed
  revoked
}

model User {
  id           String     @id @default(cuid())
  username     String     @unique
  passwordHash String     @map("password_hash")
  name         String
  role         UserRole
  department   String?
  phone        String?
  status       UserStatus @default(active)
  tokenVersion Int        @default(0) @map("token_version")
  createdBy    String?    @map("created_by")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  auditLogs            AuditLog[]
  createdWorkOrders    WorkOrder[]           @relation("WorkOrderCreator")
  approvals            Approval[]
  timelineEntries      WorkOrderTimeline[]
  uploadedFiles        RawFile[]
  uploadedImportTasks  ImportTask[]          @relation("ImportTaskUploader")
  confirmedImportTasks ImportTask[]          @relation("ImportTaskConfirmer")
  uploadedOcrTasks     OcrTask[]             @relation("OcrTaskUploader")
  confirmedOcrTasks    OcrTask[]             @relation("OcrTaskConfirmer")
  ocrCorrections       OcrCorrection[]
  aiConversations      AiConversation[]
  aiTasks              AiTask[]
  notificationReceipts NotificationReceipt[]
  retentionRuns        RetentionRun[]        @relation("RetentionRunRequester")
  retentionLegalHolds  RetentionLegalHold[]  @relation("RetentionLegalHoldCreator")
  stepUpGrants         StepUpGrant[]

  @@map("users")
}

model AuditLog {
  id            String   @id @default(cuid())
  actorUserId   String?  @map("actor_user_id")
  actorUsername String?  @map("actor_username")
  action        String
  resourceType  String   @map("resource_type")
  resourceId    String?  @map("resource_id")
  metadata      Json?
  ip            String?
  userAgent     String?  @map("user_agent")
  requestId     String?  @map("request_id")
  failureReason String?  @map("failure_reason")
  createdAt     DateTime @default(now()) @map("created_at")

  actor User? @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([resourceType, resourceId])
  @@index([requestId])
  @@map("audit_logs")
}

model Project {
  id           String        @id @default(cuid())
  name         String
  customerName String        @map("customer_name")
  description  String?
  ownerName    String        @map("owner_name")
  status       ProjectStatus @default(active)
  createdBy    String?       @map("created_by")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  projectTemplates ProjectTemplate[]
  businessRecords  BusinessRecord[]
  workOrders       WorkOrder[]
  rawFiles         RawFile[]
  importTasks      ImportTask[]
  ocrTasks         OcrTask[]
  fieldSuggestions FieldSuggestion[]
  ruleRunResults   RuleRunResult[]
  aiAnomalies      AiAnomaly[]
  mappingProfiles  MappingProfile[]

  @@index([status])
  @@map("projects")
}

model Template {
  id                   String              @id @default(cuid())
  name                 String
  recordType           DataRecordType      @map("record_type")
  accountingDirection  AccountingDirection @default(expense) @map("accounting_direction")
  dataLayer            RecordDataLayer     @default(actual) @map("data_layer")
  primaryAmountFieldId String?             @map("primary_amount_field_id")
  primaryDateFieldId   String?             @map("primary_date_field_id")
  version              Int                 @default(1)
  description          String?
  isSystem             Boolean             @default(false) @map("is_system")
  createdBy            String?             @map("created_by")
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")

  primaryAmountField FieldDefinition?  @relation("TemplatePrimaryAmountField", fields: [primaryAmountFieldId], references: [id], onDelete: Restrict)
  primaryDateField   FieldDefinition?  @relation("TemplatePrimaryDateField", fields: [primaryDateFieldId], references: [id], onDelete: Restrict)
  templateFields     TemplateField[]
  projectTemplates   ProjectTemplate[]
  businessRecords    BusinessRecord[]
  workOrders         WorkOrder[]
  importTasks        ImportTask[]
  ocrTasks           OcrTask[]
  mappingProfiles    MappingProfile[]
  fieldSuggestions   FieldSuggestion[]

  @@index([recordType])
  @@index([primaryAmountFieldId])
  @@index([primaryDateFieldId])
  @@map("templates")
}

model FieldDefinition {
  id           String       @id @default(cuid())
  fieldKey     String       @unique @map("field_key")
  fieldName    String       @map("field_name")
  fieldType    FieldType    @map("field_type")
  unit         String?
  semanticType SemanticType @map("semantic_type")
  aliases      Json?
  description  String?
  isActive     Boolean      @default(true) @map("is_active")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  templateFields      TemplateField[]
  recordValues        RecordValue[]
  mappingProfileRules MappingProfileRule[]
  mappingDecisions    MappingDecision[]
  mappedSuggestions   FieldSuggestion[]    @relation("SuggestionMappedField")
  ocrCorrections      OcrCorrection[]
  primaryAmountFor    Template[]           @relation("TemplatePrimaryAmountField")
  primaryDateFor      Template[]           @relation("TemplatePrimaryDateField")

  @@index([isActive])
  @@map("field_definitions")
}

model TemplateField {
  id           String   @id @default(cuid())
  templateId   String   @map("template_id")
  fieldId      String   @map("field_id")
  isRequired   Boolean  @default(false) @map("is_required")
  isVisible    Boolean  @default(true) @map("is_visible")
  displayOrder Int      @default(0) @map("display_order")
  defaultValue String?  @map("default_value")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  template Template        @relation(fields: [templateId], references: [id], onDelete: Cascade)
  field    FieldDefinition @relation(fields: [fieldId], references: [id], onDelete: Restrict)

  @@unique([templateId, fieldId])
  @@index([fieldId])
  @@map("template_fields")
}

model ProjectTemplate {
  id         String         @id @default(cuid())
  projectId  String         @map("project_id")
  templateId String         @map("template_id")
  recordType DataRecordType @map("record_type")
  customName String?        @map("custom_name")
  isActive   Boolean        @default(true) @map("is_active")
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")

  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([projectId, templateId])
  @@index([projectId, recordType])
  @@index([templateId])
  @@map("project_templates")
}

model BusinessRecord {
  id                   String               @id @default(cuid())
  projectId            String               @map("project_id")
  templateId           String               @map("template_id")
  recordType           DataRecordType       @map("record_type")
  accountingDirection  AccountingDirection  @default(expense) @map("accounting_direction")
  dataLayer            RecordDataLayer      @default(actual) @map("data_layer")
  templateVersion      Int                  @default(1) @map("template_version")
  templateSnapshot     Json?                @map("template_snapshot")
  sourceSnapshot       Json?                @map("source_snapshot")
  confirmationSnapshot Json?                @map("confirmation_snapshot")
  version              Int                  @default(1)
  recordDate           DateTime             @map("record_date")
  amount               Decimal              @default(0) @db.Decimal(18, 2)
  category             String?
  subCategory          String?              @map("sub_category")
  description          String?
  sourceType           RecordSourceType     @default(manual) @map("source_type")
  sourceId             String               @default("manual") @map("source_id")
  importTaskId         String?              @map("import_task_id")
  status               BusinessRecordStatus @default(pending_confirm)
  attachments          Json?
  createdBy            String?              @map("created_by")
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")
  confirmedAt          DateTime?            @map("confirmed_at")
  confirmedBy          String?              @map("confirmed_by")
  voidedAt             DateTime?            @map("voided_at")
  voidedBy             String?              @map("voided_by")

  project                Project       @relation(fields: [projectId], references: [id], onDelete: Restrict)
  template               Template      @relation(fields: [templateId], references: [id], onDelete: Restrict)
  values                 RecordValue[]
  generatedFromWorkOrder WorkOrder?    @relation("GeneratedRecord")
  importTask             ImportTask?   @relation(fields: [importTaskId], references: [id], onDelete: Restrict)
  sourceImportRow        ImportRow?    @relation("ImportRowGeneratedRecord")
  generatedFromOcrTask   OcrTask?      @relation("OcrGeneratedRecord")

  @@unique([importTaskId, sourceId], map: "uq_business_records_import_source")
  @@index([projectId])
  @@index([templateId])
  @@index([status])
  @@index([dataLayer, status, recordDate])
  @@index([recordDate])
  @@index([importTaskId])
  @@map("business_records")
}

model WorkOrder {
  id                     String          @id @default(cuid())
  orderNo                String          @unique @map("order_no")
  type                   WorkOrderType
  projectId              String          @map("project_id")
  templateId             String?         @map("template_id")
  templateVersion        Int?            @map("template_version")
  templateSnapshot       Json?           @map("template_snapshot")
  submissionSnapshot     Json?           @map("submission_snapshot")
  version                Int             @default(1)
  projectName            String          @map("project_name")
  customerName           String?         @map("customer_name")
  creatorId              String          @map("creator_id")
  creatorName            String          @map("creator_name")
  amount                 Decimal         @default(0) @db.Decimal(14, 2)
  income                 Decimal         @default(0) @db.Decimal(14, 2)
  cost                   Decimal         @default(0) @db.Decimal(14, 2)
  profit                 Decimal         @default(0) @db.Decimal(14, 2)
  status                 WorkOrderStatus @default(finance_reviewing)
  riskLevel              RiskLevel       @default(low) @map("risk_level")
  description            String?
  occurredDate           DateTime?       @map("occurred_date")
  extraValues            Json?           @map("extra_values")
  financeOpinion         String?         @map("finance_opinion")
  reviewerOpinion        String?         @map("reviewer_opinion")
  aiSummary              String?         @map("ai_summary")
  bossOpinion            String?         @map("boss_opinion")
  urgent                 Boolean         @default(false)
  urgentReason           String?         @map("urgent_reason")
  urgentTime             DateTime?       @map("urgent_time")
  createdAt              DateTime        @default(now()) @map("created_at")
  updatedAt              DateTime        @updatedAt @map("updated_at")
  submittedAt            DateTime?       @map("submitted_at")
  completedAt            DateTime?       @map("completed_at")
  generatedRecordId      String?         @unique @map("generated_record_id")
  creationIdempotencyKey String?         @unique @map("creation_idempotency_key")
  approvalIdempotencyKey String?         @unique @map("approval_idempotency_key")

  project         Project               @relation(fields: [projectId], references: [id], onDelete: Restrict)
  template        Template?             @relation(fields: [templateId], references: [id], onDelete: Restrict)
  creator         User                  @relation("WorkOrderCreator", fields: [creatorId], references: [id], onDelete: Restrict)
  generatedRecord BusinessRecord?       @relation("GeneratedRecord", fields: [generatedRecordId], references: [id], onDelete: SetNull)
  attachments     WorkOrderAttachment[]
  timeline        WorkOrderTimeline[]
  approvals       Approval[]
  notifications   Notification[]
  rawFiles        RawFile[]             @relation("RelatedWorkOrderFiles")
  ruleRunResults  RuleRunResult[]
  aiAnomalies     AiAnomaly[]

  @@index([creatorId])
  @@index([projectId])
  @@index([templateId])
  @@index([status])
  @@index([createdAt])
  @@map("work_orders")
}

model WorkOrderAttachment {
  id          String   @id @default(cuid())
  workOrderId String   @map("work_order_id")
  rawFileId   String   @map("raw_file_id")
  uploadedBy  String?  @map("uploaded_by")
  createdAt   DateTime @default(now()) @map("created_at")

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  rawFile   RawFile   @relation(fields: [rawFileId], references: [id], onDelete: Restrict)

  @@unique([workOrderId, rawFileId])
  @@index([rawFileId])
  @@map("work_order_attachments")
}

model RawFile {
  id                 String         @id @default(cuid())
  fileName           String         @map("file_name")
  originalFileName   String         @map("original_file_name")
  fileType           String         @map("file_type")
  mimeType           String         @map("mime_type")
  fileSize           BigInt         @map("file_size")
  storagePath        String         @map("storage_path")
  sha256             String
  uploadedBy         String         @map("uploaded_by")
  uploadedAt         DateTime       @default(now()) @map("uploaded_at")
  relatedProjectId   String?        @map("related_project_id")
  relatedWorkOrderId String?        @map("related_work_order_id")
  status             RawFileStatus  @default(uploaded)
  scanStatus         FileScanStatus @default(pending) @map("scan_status")
  previewStatus      String         @default("untrusted_original") @map("preview_status")
  isVoided           Boolean        @default(false) @map("is_voided")
  voidReason         String?        @map("void_reason")
  voidedAt           DateTime?      @map("voided_at")
  voidedBy           String?        @map("voided_by")

  uploader         User                  @relation(fields: [uploadedBy], references: [id], onDelete: Restrict)
  project          Project?              @relation(fields: [relatedProjectId], references: [id], onDelete: SetNull)
  relatedWorkOrder WorkOrder?            @relation("RelatedWorkOrderFiles", fields: [relatedWorkOrderId], references: [id], onDelete: SetNull)
  attachments      WorkOrderAttachment[]
  importTasks      ImportTask[]
  ocrTasks         OcrTask[]

  @@index([sha256])
  @@index([uploadedBy])
  @@index([relatedProjectId])
  @@index([relatedWorkOrderId])
  @@index([scanStatus])
  @@map("raw_files")
}

model ImportTask {
  id                         String           @id @default(cuid())
  projectId                  String           @map("project_id")
  templateId                 String           @map("template_id")
  templateVersion            Int              @default(1) @map("template_version")
  templateSnapshot           Json?            @map("template_snapshot")
  rawFileId                  String           @unique @map("raw_file_id")
  fileName                   String           @map("file_name")
  importType                 DataRecordType   @map("import_type")
  status                     ImportTaskStatus @default(uploaded)
  version                    Int              @default(1)
  leaseToken                 String?          @map("lease_token")
  leaseUntil                 DateTime?        @map("lease_until")
  parseConfig                Json?            @map("parse_config")
  parseRequestedBy           String?          @map("parse_requested_by")
  executionMode              String?          @map("execution_mode")
  processingMode             String?          @map("processing_mode")
  sourceSha256               String?          @map("source_sha256")
  parserInputSha256          String?          @map("parser_input_sha256")
  irSchemaVersion            String?          @map("ir_schema_version")
  parserVersion              String?          @map("parser_version")
  irHash                     String?          @map("ir_hash")
  rowEvidenceDigest          String?          @map("row_evidence_digest")
  processedRows              Int              @default(0) @map("processed_rows")
  parseAttempts              Int              @default(0) @map("parse_attempts")
  confirmRequestedBy         String?          @map("confirm_requested_by")
  confirmationTotalRows      Int              @default(0) @map("confirmation_total_rows")
  confirmationProcessedRows  Int              @default(0) @map("confirmation_processed_rows")
  confirmationSuccessRows    Int              @default(0) @map("confirmation_success_rows")
  confirmationErrorRows      Int              @default(0) @map("confirmation_error_rows")
  confirmationAttempts       Int              @default(0) @map("confirmation_attempts")
  confirmationStartedAt      DateTime?        @map("confirmation_started_at")
  uploadedBy                 String           @map("uploaded_by")
  createdAt                  DateTime         @default(now()) @map("created_at")
  parsedAt                   DateTime?        @map("parsed_at")
  confirmedAt                DateTime?        @map("confirmed_at")
  confirmedBy                String?          @map("confirmed_by")
  errorMessage               String?          @map("error_message")
  idempotencyKey             String?          @unique @map("idempotency_key")
  totalRows                  Int              @default(0) @map("total_rows")
  validRows                  Int              @default(0) @map("valid_rows")
  errorRows                  Int              @default(0) @map("error_rows")
  duplicateRows              Int              @default(0) @map("duplicate_rows")
  ignoredRows                Int              @default(0) @map("ignored_rows")
  importedRows               Int              @default(0) @map("imported_rows")
  previewSummaryVersion      Int?             @map("preview_summary_version")
  structureFingerprint       String?          @map("structure_fingerprint")
  fingerprintVersion         String?          @map("fingerprint_version")
  transformRegistryVersion   String?          @map("transform_registry_version")
  mappingProfileId           String?          @map("mapping_profile_id")
  mappingProfileVersion      Int?             @map("mapping_profile_version")
  mappingProfileSnapshotHash String?          @map("mapping_profile_snapshot_hash")

  project          Project           @relation(fields: [projectId], references: [id], onDelete: Restrict)
  template         Template          @relation(fields: [templateId], references: [id], onDelete: Restrict)
  rawFile          RawFile           @relation(fields: [rawFileId], references: [id], onDelete: Restrict)
  uploader         User              @relation("ImportTaskUploader", fields: [uploadedBy], references: [id], onDelete: Restrict)
  confirmer        User?             @relation("ImportTaskConfirmer", fields: [confirmedBy], references: [id], onDelete: SetNull)
  sheets           ImportSheet[]
  columns          ImportColumn[]
  rows             ImportRow[]
  mappingDecisions MappingDecision[]
  fieldSuggestions FieldSuggestion[]
  businessRecords  BusinessRecord[]
  mappingProfile   MappingProfile?   @relation("AppliedMappingProfile", fields: [mappingProfileId], references: [id], onDelete: SetNull)

  @@index([projectId, createdAt])
  @@index([status, leaseUntil])
  @@index([templateId])
  @@index([status])
  @@index([uploadedBy])
  @@index([irHash])
  @@index([structureFingerprint])
  @@index([mappingProfileId])
  @@map("import_tasks")
}

model ImportSheet {
  id                  String   @id @default(cuid())
  importTaskId        String   @map("import_task_id")
  stableId            String?  @map("stable_id")
  sheetName           String   @map("sheet_name")
  sheetIndex          Int      @map("sheet_index")
  visibility          String?  @map("visibility")
  headerStartRowIndex Int?     @map("header_start_row_index")
  headerRowIndex      Int      @default(1) @map("header_row_index")
  selectedHeaderRows  Json     @default("[]") @map("selected_header_rows")
  mergedRanges        Json     @default("[]") @map("merged_ranges")
  dateSystem          String?  @map("date_system")
  timezone            String?  @map("timezone")
  rowCount            Int      @default(0) @map("row_count")
  createdAt           DateTime @default(now()) @map("created_at")

  importTask ImportTask     @relation(fields: [importTaskId], references: [id], onDelete: Cascade)
  columns    ImportColumn[]
  rows       ImportRow[]

  @@unique([importTaskId, sheetIndex])
  @@index([importTaskId])
  @@map("import_sheets")
}

model ImportColumn {
  id             String   @id @default(cuid())
  importTaskId   String   @map("import_task_id")
  sheetId        String   @map("sheet_id")
  columnIndex    Int      @map("column_index")
  sourceColumnId String?  @map("source_column_id")
  columnLetter   String?  @map("column_letter")
  sourceKey      String   @map("source_key")
  sourceName     String   @map("source_name")
  headerParts    Json     @default("[]") @map("header_parts")
  normalizedName String   @map("normalized_name")
  sampleValues   Json     @default("[]") @map("sample_values")
  inferredType   String   @map("inferred_type")
  duplicateName  Boolean  @default(false) @map("duplicate_name")
  statistics     Json     @default("{}") @map("statistics_json")
  createdAt      DateTime @default(now()) @map("created_at")

  importTask ImportTask       @relation(fields: [importTaskId], references: [id], onDelete: Cascade)
  sheet      ImportSheet      @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  decision   MappingDecision?
  suggestion FieldSuggestion?

  @@unique([sheetId, columnIndex])
  @@unique([importTaskId, sourceKey])
  @@index([importTaskId])
  @@map("import_columns")
}

model ImportRow {
  id                      String          @id @default(cuid())
  importTaskId            String          @map("import_task_id")
  sheetId                 String          @map("sheet_id")
  rowNumber               Int             @map("row_number")
  rawData                 Json            @map("raw_data_json")
  normalizedData          Json?           @map("normalized_data_json")
  rowHash                 String          @map("row_hash")
  status                  ImportRowStatus @default(pending)
  errors                  Json            @default("[]")
  warnings                Json            @default("[]")
  cellEvidence            Json            @default("[]") @map("cell_evidence_json")
  evidenceHash            String?         @map("evidence_hash")
  confirmedAt             DateTime?       @map("confirmed_at")
  confirmationProcessedAt DateTime?       @map("confirmation_processed_at")
  generatedRecordId       String?         @unique @map("generated_record_id")
  createdAt               DateTime        @default(now()) @map("created_at")

  importTask      ImportTask      @relation(fields: [importTaskId], references: [id], onDelete: Cascade)
  sheet           ImportSheet     @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  generatedRecord BusinessRecord? @relation("ImportRowGeneratedRecord", fields: [generatedRecordId], references: [id], onDelete: SetNull)

  @@unique([sheetId, rowNumber])
  @@index([importTaskId, status])
  @@index([importTaskId, confirmationProcessedAt, rowNumber], map: "idx_import_rows_confirmation_queue")
  @@index([rowHash])
  @@index([evidenceHash])
  @@map("import_rows")
}

model MappingProfile {
  id                         String               @id @default(cuid())
  projectId                  String?              @map("project_id")
  templateId                 String               @map("template_id")
  templateVersion            Int                  @default(1) @map("template_version")
  name                       String
  profileVersion             Int                  @default(1) @map("profile_version")
