model AiCallAttempt {
  id               String              @id @default(cuid())
  aiTaskId         String              @map("ai_task_id")
  deploymentId     String?             @map("deployment_id")
  promptVersionId  String?             @map("prompt_version_id")
  attemptNo        Int                 @map("attempt_no")
  status           AiCallAttemptStatus @default(queued)
  provider         String
  modelName        String              @map("model_name")
  modelVersion     String?             @map("model_version")
  endpointSnapshot String?             @map("endpoint_snapshot")
  inputHash        String              @map("input_hash")
  outputPayload    Json?               @map("output_payload")
  outputRef        String?             @map("output_ref")
  latencyMs        Int?                @map("latency_ms")
  inputTokens      Int                 @default(0) @map("input_tokens")
  outputTokens     Int                 @default(0) @map("output_tokens")
  unitCount        Int                 @default(0) @map("unit_count")
  retry            Boolean             @default(false)
  fallback         Boolean             @default(false)
  errorMessage     String?             @map("error_message")
  correlationId    String              @map("correlation_id")
  startedAt        DateTime?           @map("started_at")
  completedAt      DateTime?           @map("completed_at")
  createdAt        DateTime            @default(now()) @map("created_at")

  aiTask        AiTask           @relation(fields: [aiTaskId], references: [id], onDelete: Cascade)
  deployment    ModelDeployment? @relation(fields: [deploymentId], references: [id], onDelete: SetNull)
  promptVersion AiPromptVersion? @relation(fields: [promptVersionId], references: [id], onDelete: SetNull)

  @@unique([aiTaskId, attemptNo])
  @@index([deploymentId, createdAt])
  @@index([correlationId])
  @@map("ai_call_attempts")
}

model AiPromptVersion {
