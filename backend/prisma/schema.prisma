  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([notificationId, userId])
  @@index([userId, readAt])
  @@map("notification_receipts")
}

model RiskRule {
  id            String    @id @default(cuid())
  ruleKey       String    @unique @map("rule_key")
  ruleName      String    @map("rule_name")
  ruleType      String    @map("rule_type")
  targetType    String    @default("work_order") @map("target_type")
  severity      RiskLevel @default(medium)
  conditionJson Json      @map("condition_json")
  description   String?
  isActive      Boolean   @default(true) @map("is_active")
  createdBy     String?   @map("created_by")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  runResults RuleRunResult[]
