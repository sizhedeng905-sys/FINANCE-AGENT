NODE_ENV="development"
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/finance_agent_dev?schema=public"
TEST_DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/finance_agent_test?schema=public"
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN=8h
HOST=127.0.0.1
PORT=3001
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SWAGGER_ENABLED=true
TRUST_PROXY_HOPS=0
# In production, list exact trusted proxy IPs/CIDRs instead of hop counting.
TRUSTED_PROXIES=
REQUEST_RATE_LIMIT_WINDOW_MS=60000
REQUEST_RATE_LIMIT_MAX=600
SEED_ALLOW_NONSTANDARD_DATABASE=false
# Example for the default dev database: reset-demo-users:finance_agent_dev
SEED_DEMO_CONFIRMATION=
UPLOAD_DIR="uploads"
MAX_FILE_SIZE_MB=10
FILE_USER_QUOTA_MB=500
FILE_PROJECT_QUOTA_MB=5000
FILE_MINIMUM_FREE_MB=1024
# Development may use basic structural validation. Production requires clamav.
FILE_SCAN_MODE=basic
CLAMAV_HOST=127.0.0.1
CLAMAV_PORT=3310
FILE_SCAN_TIMEOUT_MS=15000
# Legacy .xls files are converted in a read-only, resource-limited Node.js child process.
XLS_CONVERTER_TIMEOUT_MS=30000
XLS_CONVERTER_MAX_OUTPUT_MB=50
AI_PROVIDER="mock"
AI_MODEL="gpt-5.4-mini"
AI_BASE_URL="https://api.openai.com/v1"
AI_API_KEY=""
AI_TIMEOUT_MS=30000
AI_MAX_OUTPUT_TOKENS=1200
AI_MAX_RESPONSE_BYTES=2097152
# Local runtime routes read these names from model_deployments.secret_ref.
VL_API_KEY=""
EMBEDDING_API_KEY=""
OCR_PROVIDER=mock
OCR_MODEL=mock-ocr-v1
OCR_MODEL_VERSION=v1
OCR_BASE_URL=http://127.0.0.1:8868
OCR_API_KEY=
OCR_TIMEOUT_MS=30000
OCR_LOW_CONFIDENCE_THRESHOLD=0.8
OCR_MAX_PDF_PAGES=20
OCR_MAX_RETRIES=2
OCR_MAX_RESPONSE_BYTES=2097152
MODEL_HTTP_MAX_RETRIES=1
MODEL_CIRCUIT_FAILURE_THRESHOLD=3
MODEL_CIRCUIT_RESET_MS=30000
MODEL_MAX_QUEUE=20
AI_MAX_CONCURRENCY=1
OCR_MAX_CONCURRENCY=1
