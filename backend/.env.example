NODE_ENV="development"
PROCESS_ROLE=all
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/finance_agent_dev?schema=public"
TEST_DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/finance_agent_test?schema=public"
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN=8h
JWT_ISSUER=finance-agent
JWT_AUDIENCE=finance-agent-api
JWT_ALGORITHM=HS256
HOST=127.0.0.1
PORT=3001
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SWAGGER_ENABLED=true
TRUST_PROXY_HOPS=0
# In production, list exact trusted proxy IPs/CIDRs instead of hop counting.
TRUSTED_PROXIES=
REQUEST_RATE_LIMIT_WINDOW_MS=60000
REQUEST_RATE_LIMIT_MAX=600
# Production requires redis and a REDIS_URL with authentication.
REQUEST_RATE_LIMIT_STORE=memory
LOGIN_RATE_LIMIT_STORE=memory
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_BLOCK_MS=900000
LOGIN_RATE_LIMIT_LEASE_MS=30000
UPLOAD_ADMISSION_STORE=memory
UPLOAD_ADMISSION_LEASE_MS=30000
REDIS_URL=
REDIS_KEY_PREFIX=finance-agent
REDIS_CONNECT_TIMEOUT_MS=5000
WORKER_POLL_INTERVAL_MS=5000
WORKER_HEARTBEAT_INTERVAL_MS=5000
WORKER_HEARTBEAT_TTL_MS=20000

# Retention deletion remains disabled pending H12/H14. dry-run only inventories candidates.
DATA_RETENTION_MODE=disabled
DATA_RETENTION_BATCH_SIZE=100
DATA_RETENTION_LEASE_MS=60000
DATA_RETENTION_MAX_ATTEMPTS=3

# H10 remains pending. Enable only after approving the exact registered actions.
STEP_UP_MODE=disabled
STEP_UP_TTL_SECONDS=300
STEP_UP_ENFORCED_ACTIONS=
METRICS_TOKEN=
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=
OTEL_SERVICE_NAME=finance-agent-api
OTEL_TRACE_BATCH_SIZE=100
OTEL_TRACE_MAX_QUEUE=1000
OTEL_TRACE_FLUSH_INTERVAL_MS=2000
SEED_ALLOW_NONSTANDARD_DATABASE=false
# Example for the default dev database: reset-demo-users:finance_agent_dev
SEED_DEMO_CONFIRMATION=
UPLOAD_DIR="uploads"
# Development defaults to local. Production requires private S3-compatible storage.
FILE_STORAGE_DRIVER=local
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true
# Required with FILE_STORAGE_DRIVER=s3. This is an application logical quota,
# not MinIO/S3 physical free space; physical capacity must be monitored separately.
S3_LOGICAL_QUOTA_BYTES=1099511627776
S3_PRESIGNED_URL_TTL_SECONDS=60
STORAGE_CAPACITY_MAX_STALENESS_SECONDS=60
UPLOAD_QUARANTINE_DIR=".upload-quarantine"
UPLOAD_QUARANTINE_MAX_AGE_MS=3600000
MAX_FILE_SIZE_MB=10
UPLOAD_MAX_CONCURRENT_PER_USER=5
UPLOAD_MAX_INFLIGHT_MB_PER_USER=260
UPLOAD_RATE_WINDOW_MS=60000
UPLOAD_RATE_MAX_PER_USER=60
FILE_USER_QUOTA_MB=500
FILE_PROJECT_QUOTA_MB=5000
FILE_MINIMUM_FREE_MB=1024
# Development may use basic structural validation. Production requires clamav.
FILE_SCAN_MODE=basic
CLAMAV_HOST=127.0.0.1
CLAMAV_PORT=3310
FILE_SCAN_TIMEOUT_MS=15000
FILE_IMAGE_MAX_WIDTH=20000
FILE_IMAGE_MAX_HEIGHT=20000
FILE_IMAGE_MAX_PIXELS=100000000
FILE_IMAGE_MAX_DECODED_MB=400
FILE_PDF_MAX_PAGES=200
FILE_PDF_MAX_OBJECTS=100000
FILE_PARSE_TIMEOUT_MS=5000
# Legacy .xls files are converted in a read-only, resource-limited Node.js child process.
XLS_CONVERTER_TIMEOUT_MS=30000
XLS_CONVERTER_MAX_OUTPUT_MB=50
AI_PROVIDER="mock"
AI_PROVIDER_CLASS="mock"
AI_INGESTION_MODE="disabled"
AI_REPORT_MODE="disabled"
AI_GLOBAL_KILL_SWITCH="false"
AI_EXTERNAL_PROVIDER_MODE="disabled"
# Production requires an explicit profile and read-only startup verification.
AI_SYSTEM_REGISTRY_PROFILE="development-local-v1"
AI_SYSTEM_REGISTRY_STARTUP_MODE="disabled"
# Used only when AI_SYSTEM_REGISTRY_PROFILE=custom. Secrets are referenced by env name, never embedded here.
AI_SYSTEM_REGISTRY_MANIFEST_JSON=""
AI_MODEL="gpt-5.4-mini"
AI_BASE_URL="https://api.openai.com/v1"
AI_API_KEY=""
AI_TIMEOUT_MS=30000
AI_MAX_OUTPUT_TOKENS=1200
AI_MAX_RESPONSE_BYTES=2097152
AI_AUDIT_RETENTION_DAYS=90
# Local runtime routes read these names from model_deployments.secret_ref.
VL_API_KEY=""
EMBEDDING_API_KEY=""
OCR_PROVIDER=mock
OCR_MODEL=mock-ocr-v1
OCR_MODEL_VERSION=v1
OCR_BASE_URL=http://127.0.0.1:8868
OCR_API_KEY=
OCR_TIMEOUT_MS=30000
OCR_LOW_CONFIDENCE_THRESHOLD=0.8
OCR_MAX_PDF_PAGES=20
OCR_MAX_RETRIES=2
OCR_PROCESSING_LEASE_MS=90000
OCR_RECOVERY_INTERVAL_MS=5000
OCR_MAX_RESPONSE_BYTES=2097152
IMPORT_CONFIRM_BATCH_SIZE=500
IMPORT_CONFIRM_LEASE_MS=60000
IMPORT_CONFIRM_MAX_ATTEMPTS=3
MODEL_HTTP_MAX_RETRIES=1
MODEL_CIRCUIT_FAILURE_THRESHOLD=3
MODEL_CIRCUIT_RESET_MS=30000
MODEL_EXECUTION_GATE_STORE=memory
MODEL_MAX_QUEUE=20
MODEL_QUEUE_WAIT_TIMEOUT_MS=60000
MODEL_EXECUTION_LEASE_MS=30000
MODEL_QUEUE_WAITER_LEASE_MS=5000
MODEL_QUEUE_POLL_MS=100
AI_MAX_CONCURRENCY=1
OCR_MAX_CONCURRENCY=1
