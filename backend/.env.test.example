NODE_ENV="test"
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/finance_agent_test?schema=public"
TEST_DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/finance_agent_test?schema=public"
JWT_SECRET="replace-with-a-different-long-random-test-secret"
PORT=3002
CORS_ORIGINS=http://127.0.0.1:4173,http://127.0.0.1:4174
SWAGGER_ENABLED=true
TRUST_PROXY_HOPS=0
REQUEST_RATE_LIMIT_WINDOW_MS=60000
REQUEST_RATE_LIMIT_MAX=5000
SEED_ALLOW_NONSTANDARD_DATABASE=false
UPLOAD_DIR="test-uploads"
MAX_FILE_SIZE_MB=5
XLS_CONVERTER_TIMEOUT_MS=30000
XLS_CONVERTER_MAX_OUTPUT_MB=50
AI_PROVIDER="mock"
AI_MODEL="mock-structured-v1"
AI_BASE_URL="http://127.0.0.1:11434/v1"
AI_API_KEY=""
AI_TIMEOUT_MS=5000
OCR_PROVIDER=mock
OCR_MODEL=mock-ocr-v1
OCR_MODEL_VERSION=1
OCR_BASE_URL=http://127.0.0.1:8868
OCR_API_KEY=
OCR_TIMEOUT_MS=5000
OCR_LOW_CONFIDENCE_THRESHOLD=0.8
OCR_MAX_PDF_PAGES=20
OCR_MAX_RETRIES=2
MODEL_HTTP_MAX_RETRIES=0
MODEL_CIRCUIT_FAILURE_THRESHOLD=3
MODEL_CIRCUIT_RESET_MS=30000
MODEL_MAX_QUEUE=20
AI_MAX_CONCURRENCY=1
OCR_MAX_CONCURRENCY=1
