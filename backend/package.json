{
  "name": "finance-agent-backend",
  "version": "0.10.0",
  "private": true,
  "description": "FINANCE-AGENT phase 0-10 backend.",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=24.18.0 <25"
  },
  "scripts": {
    "dev": "node --watch --require ts-node/register/transpile-only src/main.ts",
    "dev:worker": "node --watch --require ts-node/register/transpile-only src/worker.ts",
    "start:e2e": "node --require ts-node/register/transpile-only src/main.ts",
    "build": "npm run prisma:generate && tsc -p tsconfig.build.json && tsc -p tsconfig.scripts.json",
    "start": "node dist/main.js",
    "start:worker": "node dist/worker.js",
    "test": "npm run prisma:generate && jest --runInBand",
    "test:integration": "node scripts/run-integration-tests.mjs",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:seed": "tsx prisma/seed.ts",
    "db:verify": "tsx scripts/verify-database.ts",
    "db:migration-paths": "node scripts/verify-migration-paths.mjs",
    "realdata:scan": "tsx scripts/scan-real-business-data.ts",
    "realdata:xlsx-profile": "tsx scripts/profile-real-xlsx.ts",
    "realdata:xls-profile": "tsx scripts/profile-real-xls.ts",
    "realdata:large-xlsx-profile": "tsx scripts/profile-large-xlsx.ts",
    "realdata:ocr-prepare": "tsx scripts/prepare-real-ocr-evaluation.ts",
    "realdata:ocr-evaluate": "tsx scripts/run-real-ocr-evaluation.ts",
    "realdata:ocr-freeze": "tsx scripts/freeze-ocr-labels.ts",
    "realdata:ocr-page-ranges": "tsx scripts/profile-real-ocr-page-ranges.ts",
    "realdata:ai-benchmark": "tsx scripts/run-ai-benchmark.ts",
    "realdata:resilience": "node scripts/profile-service-resilience.mjs",
    "realdata:model-resilience": "node scripts/profile-model-resilience.mjs",
    "model:soak": "node scripts/monitor-resident-models.mjs",
    "model:routes": "tsx scripts/configure-model-runtime.ts",
    "model:check": "node scripts/verify-model-assets.mjs resident",
    "model:check:all": "node scripts/verify-model-assets.mjs all",
    "model:services:init": "node scripts/model-services.mjs init",
    "model:services:resident": "node scripts/model-services.mjs start-resident",
    "model:services:on-demand": "node scripts/model-services.mjs start-on-demand",
    "model:services:restore": "node scripts/model-services.mjs stop-on-demand",
    "model:services:status": "node scripts/model-services.mjs status",
    "model:services:stop": "node scripts/model-services.mjs stop-all",
    "model:lock:test": "node scripts/test-model-switch-lock.mjs",
    "model:switch:acceptance": "node scripts/test-live-model-switch.mjs",
    "model:ocr:acceptance": "node scripts/test-live-paddle-ocr.mjs",
    "model:key:rotate": "node scripts/rotate-local-model-key.mjs",
    "model:config:check": "node scripts/check-model-deployment-config.mjs",
    "model:sbom": "node scripts/scan-model-images.mjs --sbom-only",
    "model:cve": "node scripts/scan-model-images.mjs --cve-only",
    "model:cve:offline": "node scripts/scan-model-sboms-grype.mjs",
    "model:security": "node scripts/scan-model-images.mjs",
    "proxy:config:check": "node scripts/test-nginx-upload-boundary.mjs --config-only",
    "proxy:boundary:test": "node scripts/test-nginx-upload-boundary.mjs",
    "uat:init": "tsx scripts/run-finance-uat.ts init",
    "uat:validate": "tsx scripts/run-finance-uat.ts validate",
    "uat:reconcile": "tsx scripts/run-finance-uat.ts reconcile"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1089.0",
    "@aws-sdk/s3-request-presigner": "3.1089.0",
    "@nestjs/common": "^11.1.28",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.28",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.1.28",
    "@nestjs/swagger": "^11.4.5",
    "@prisma/client": "6.19.3",
    "ajv": "^8.18.0",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "exceljs": "^4.4.0",
    "helmet": "^8.1.0",
    "pdf-lib": "^1.17.1",
    "prisma": "6.19.3",
    "redis": "6.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "saxes": "^5.0.1",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "yauzl": "^3.4.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.28",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.10.2",
    "@types/supertest": "^6.0.2",
    "@types/yauzl": "^2.10.3",
    "jest": "^29.7.0",
    "jszip": "^3.10.1",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "overrides": {
    "exceljs": {
      "uuid": "^11.1.1"
    }
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "testEnvironment": "node"
  }
}
